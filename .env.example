# Database
DATABASE_URL=postgresql://user:password@localhost:5432/avt_auto

# Server
PORT=3001
NODE_ENV=development
# Optional: comma-separated list of browser origins allowed to call the API.
# Leave empty in local development; set in production, for example:
# CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=

# Admin access
# Required in production to enable admin login safely
ADMIN_PASSWORD=
# Optional: custom secret for admin session tokens
ADMIN_SESSION_SECRET=

# Public auth
# Optional: session lifetime in days for login/password sessions
AUTH_SESSION_TTL_DAYS=30
# Set to false in production if self-service registration should be disabled
AUTH_ALLOW_REGISTRATION=true

# Encar scraping mode
# If set, scraper will call this Vercel endpoint instead of direct api.encar.com.
# Example: https://encar-proxy-vercel.vercel.app/api/proxy
ENCAR_PROXY_URL=https://encar-proxy-vercel.vercel.app/api/proxy

# Optional: Carapis key (only for standalone tests/tools)
CARAPIS_API_KEY=
