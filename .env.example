# ── База данных (обязательно) ────────────────────────────────────────────────
# Railway автоматически подставляет эту переменную при добавлении PostgreSQL-сервиса
DATABASE_URL=postgresql://user:password@localhost:5432/avt_auto

# ── Сервер ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development    # на Railway ставить: production

# ── Опционально ─────────────────────────────────────────────────────────────
# BASE_URL=https://ваш-домен.railway.app
